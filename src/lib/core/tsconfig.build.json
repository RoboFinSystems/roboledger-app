{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "skipLibCheck": true,
    "incremental": false,
    "outDir": "./dist"
  },
  "include": ["index.ts", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "scripts",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
